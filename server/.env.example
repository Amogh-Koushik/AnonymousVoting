# Server Environment Variables
# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/anonymous-voting?retryWrites=true&w=majority

# Firebase Admin SDK (paste the JSON values from your Firebase service account key)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Admin email (users with this email get admin role)
ADMIN_EMAIL=amoghnkoushik@gmail.com

# Server
PORT=5000
NODE_ENV=development

# CORS - Frontend URL
CLIENT_URL=http://localhost:5173
